# ══════════════════════════════════════════════════════════════════
#  RÚBRICA — Variables de Entorno
#  Archivo: /opt/rubrica/.env
#  ⚠️  NUNCA subir este archivo a Git
#  ⚠️  chmod 600 .env  (solo lectura para el owner)
# ══════════════════════════════════════════════════════════════════

# ─── DOMINIO ────────────────────────────────────────────────────────
DOMAIN=rubrica.com.mx
APP_URL=https://app.rubrica.com.mx
API_URL=https://api.rubrica.com.mx
ADMIN_URL=https://admin.rubrica.com.mx

# ─── POSTGRESQL ─────────────────────────────────────────────────────
POSTGRES_DB=rubrica_prod
POSTGRES_USER=rubrica_user
# ⚠️ Cambiar por contraseña segura (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_POSTGRES_PASSWORD_AQUI

# ─── REDIS ──────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 24
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD_AQUI

# ─── DOCUSEAL ───────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
DOCUSEAL_SECRET_KEY_BASE=CAMBIAR_DOCUSEAL_SECRET_AQUI

# ─── STIRLING-PDF ───────────────────────────────────────────────────
# Generar con: openssl rand -base64 16
STIRLING_ADMIN_PASSWORD=CAMBIAR_STIRLING_PASSWORD_AQUI

# ─── API GATEWAY / JWT ──────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_JWT_SECRET_AQUI
JWT_EXPIRY=24h
# Generar con: openssl rand -hex 32
ADMIN_JWT_SECRET=CAMBIAR_ADMIN_JWT_SECRET_AQUI

# ─── ADMIN PANEL ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rubrica.com.mx
# Generar con: openssl rand -base64 16
ADMIN_PASSWORD=CAMBIAR_ADMIN_PASSWORD_AQUI
# Tu IP fija (para restricción de acceso al panel admin)
# Dejar en blanco para no restringir (NO recomendado en producción)
ADMIN_ALLOWED_IPS=

# ─── BREVO SMTP ─────────────────────────────────────────────────────
# Obtener en: app.brevo.com → SMTP & API → SMTP tab
BREVO_SMTP_USER=TU_EMAIL_DE_CUENTA_BREVO_AQUI
BREVO_SMTP_KEY=TU_SMTP_KEY_DE_BREVO_AQUI

# ─── MINIO (Almacenamiento) ─────────────────────────────────────────
MINIO_ROOT_USER=rubrica_admin
# Generar con: openssl rand -base64 24
MINIO_ROOT_PASSWORD=CAMBIAR_MINIO_PASSWORD_AQUI

# ─── WORDPRESS / EDD ────────────────────────────────────────────────
# Generar un secret compartido con EDD (cualquier string aleatorio)
# Generar con: openssl rand -hex 32
EDD_WEBHOOK_SECRET=CAMBIAR_EDD_WEBHOOK_SECRET_AQUI
EDD_API_URL=https://TU_WORDPRESS.com/wp-json/edd/v2
EDD_API_KEY=TU_EDD_API_KEY_AQUI
EDD_API_TOKEN=TU_EDD_API_TOKEN_AQUI

# ─── PSC NOM-151 ────────────────────────────────────────────────────
# Proveedor recomendado: Mifiel (mifiel.com)
# Alternativa: SeguriData, ATEB
PSC_PROVIDER=mifiel
PSC_API_KEY=TU_API_KEY_DEL_PSC_AQUI
PSC_API_URL=https://app.mifiel.com/api/v1
# En sandbox para pruebas:
# PSC_API_URL=https://sandbox.mifiel.com/api/v1

# ─── MAPEO PLANES EDD → RÚBRICA ────────────────────────────────────
# IDs de productos en tu WordPress/EDD
EDD_PRODUCT_ID_ESENCIAL=1
EDD_PRODUCT_ID_PROFESIONAL=2
EDD_PRODUCT_ID_EMPRESARIAL=3
